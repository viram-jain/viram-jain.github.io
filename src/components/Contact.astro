---
import { getEntry } from 'astro:content';
import { site } from '../data/site';

const contact = await getEntry('site', 'contact');
if (!contact) throw new Error('Missing site/contact.md content entry');
const { Content } = await contact.render();
const { title, buttonText } = contact.data;
---

<section id="contact" class="contact">
  <p class="eyebrow reveal">04. What's Next?</p>
  <h2 class="reveal" style="--reveal-delay: 0.06s"><span class="gradient-text">{title}</span></h2>
  <div class="contact-copy reveal" style="--reveal-delay: 0.12s">
    <Content />
  </div>
  <a class="cta reveal" style="--reveal-delay: 0.18s" href={`mailto:${site.email}`}>{buttonText}</a>
</section>

<style>
  .contact {
    text-align: center;
    max-width: 600px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    color: var(--accent);
    margin: 0 0 1rem;
  }

  h2 {
    font-size: clamp(1.8rem, 6vw, 3rem);
    margin: 0 0 1.25rem;
  }

  .contact-copy {
    color: var(--text-dim);
  }

  .cta {
    position: relative;
    display: inline-block;
    margin-top: 2.5rem;
    padding: 1rem 1.75rem;
    border: 1px solid var(--accent);
    border-radius: 6px;
    color: var(--text-bright);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    overflow: hidden;
    z-index: 0;
    transition: border-color 0.35s var(--ease);
  }

  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gradient);
    transform: translateX(-101%);
    transition: transform 0.35s var(--ease);
    z-index: -1;
  }

  .cta:hover {
    border-color: transparent;
  }

  .cta:hover::before {
    transform: translateX(0);
  }
</style>
