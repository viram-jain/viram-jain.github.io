---
import { site } from '../data/site';
import IconGitHub from './icons/IconGitHub.astro';
import IconLinkedIn from './icons/IconLinkedIn.astro';
import IconInstagram from './icons/IconInstagram.astro';
import IconMail from './icons/IconMail.astro';

const icons: Record<string, any> = {
  GitHub: IconGitHub,
  LinkedIn: IconLinkedIn,
  Instagram: IconInstagram,
};
---

<footer class="footer">
  <ul class="social">
    {
      site.social.map((s) => {
        const Icon = icons[s.name];
        return (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name}>
              <Icon size={20} />
            </a>
          </li>
        );
      })
    }
    <li>
      <a href={`mailto:${site.email}`} aria-label="Email">
        <IconMail size={20} />
      </a>
    </li>
  </ul>
  <p>Built by {site.name}.</p>
</footer>

<style>
  .footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    padding: 3rem 1.5rem 3rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    background: var(--bg);
  }

  .social {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .social a {
    color: var(--text-dim);
    display: inline-flex;
    transition:
      color 0.3s ease,
      transform 0.3s ease;
  }

  .social a:hover {
    color: var(--accent-2);
    transform: translateY(-3px);
  }
</style>
