  <rect x="2.5" y="2.5" width="19" height="19" rx="5"></rect>
  <circle cx="12" cy="12" r="4.5"></circle>
  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
</svg>
