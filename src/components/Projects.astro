---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import IconFolder from './icons/IconFolder.astro';
import IconGitHub from './icons/IconGitHub.astro';
import IconExternal from './icons/IconExternal.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.showInProjects)
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  projects.map(async (project) => ({ project, Content: (await project.render()).Content }))
);
---

<section id="projects" class="projects">
  <h2 class="section-heading reveal" data-number="03.">Things I've Built</h2>
  <div class="project-grid">
    {
      rendered.map(({ project, Content }, i) => (
        <article class="project-card reveal" style={`--reveal-delay: ${i * 0.08}s`}>
          <div class="project-cover">
            <Image src={project.data.cover} alt={project.data.title} width={640} height={360} />
          </div>
          <div class="project-top">
            <IconFolder size={32} />
            <div class="project-links">
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub repository">
                  <IconGitHub size={20} />
                </a>
              )}
              {project.data.external && (
                <a href={project.data.external} target="_blank" rel="noopener noreferrer" aria-label="Live demo">
                  <IconExternal size={20} />
                </a>
              )}
            </div>
          </div>
          <h3>{project.data.title}</h3>
          <div class="project-desc">
            <Content />
          </div>
          <ul class="tech-list">
            {project.data.tech.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  .project-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.4s var(--ease),
      border-color 0.4s var(--ease),
      box-shadow 0.4s var(--ease);
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }

  .project-cover {
    border-radius: 8px;
    overflow: hidden;
    margin: -1.75rem -1.75rem 1.25rem;
  }

  .project-cover :global(img) {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.5s var(--ease);
  }

  .project-card:hover .project-cover :global(img) {
    transform: scale(1.06);
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--accent);
  }

  .project-links {
    display: flex;
    gap: 0.9rem;
    color: var(--text-dim);
  }

  .project-links a {
    transition:
      color 0.25s ease,
      transform 0.25s ease;
    display: inline-flex;
  }

  .project-links a:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }

  h3 {
    margin: 1rem 0 0.5rem;
    font-size: 1.2rem;
  }

  .project-desc {
    color: var(--text-dim);
    flex-grow: 1;
  }

  .project-desc :global(p) {
    margin: 0;
  }

  .tech-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    margin: 1.25rem 0 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
  }
</style>
