---
import { getCollection } from 'astro:content';

const jobs = await getCollection('jobs');
jobs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rendered = await Promise.all(
  jobs.map(async (job) => ({ job, Content: (await job.render()).Content }))
);
---

<section id="jobs" class="jobs">
  <h2 class="section-heading reveal" data-number="02.">Where I've Worked</h2>
  <ol class="job-list">
    {
      rendered.map(({ job, Content }, i) => (
        <li class="job reveal" style={`--reveal-delay: ${i * 0.06}s`}>
          <span class="dot" />
          <div class="job-heading">
            <h3>
              {job.data.title} <span class="at">@</span>{' '}
              <a href={job.data.url} target="_blank" rel="noopener noreferrer" class="company">
                {job.data.company}
              </a>
            </h3>
            <p class="range">{job.data.range}</p>
          </div>
          <div class="job-body">
            <Content />
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .job-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .job {
    position: relative;
    border-left: 2px solid var(--border);
    padding-left: 1.75rem;
    transition: border-color 0.3s ease;
  }

  .job:hover {
    border-color: var(--accent);
  }

  .dot {
    position: absolute;
    left: -6px;
    top: 0.4rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gradient);
    box-shadow: 0 0 0 4px var(--bg);
  }

  .job-heading h3 {
    font-size: 1.15rem;
    margin: 0;
  }

  .at {
    color: var(--accent);
  }

  .company {
    color: var(--accent);
  }

  .company:hover {
    text-decoration: underline;
  }

  .range {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: 0.25rem 0 0.9rem;
  }

  .job-body :global(ul) {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .job-body :global(li) {
    position: relative;
    padding-left: 1.3rem;
    margin-bottom: 0.6rem;
    color: var(--text-dim);
  }

  .job-body :global(li::before) {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .job-body :global(a) {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--border);
  }
</style>
