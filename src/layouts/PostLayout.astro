---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | Viram Jain`} description={description}>
  <Header />
  <main>
    <article class="post">
      <a class="back-link" href="/blog">&larr; Back to all posts</a>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {
          tags.length > 0 && (
            <ul class="tags">
              {tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
      </div>
      <div class="post-body">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    margin: 0 0 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .tags {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags li {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.15rem 0.7rem;
  }

  .post-body :global(a) {
    color: var(--accent);
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(h2) {
    margin-top: 2.5rem;
  }
</style>
