---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404: Not Found | Viram Jain">
  <Header />
  <main>
    <section class="not-found">
      <p class="code">404</p>
      <h1>Page not found</h1>
      <a class="cta" href="/">Go back home</a>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .not-found {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .code {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 1.1rem;
    margin: 0 0 1rem;
  }

  h1 {
    margin: 0 0 2rem;
  }

  .cta {
    display: inline-block;
    padding: 1rem 1.75rem;
    border: 1px solid var(--accent);
    border-radius: 4px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .cta:hover {
    background: var(--accent-dim);
  }
</style>
